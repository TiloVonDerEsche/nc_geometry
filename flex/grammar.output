Terminals unused in grammar

    SEMICOLON
    OTHER
    EQ
    NEQ
    LTEQ
    GTEQ


Grammar

    0 $accept: prog $end

    1 prog: lines

    2 lines: ε
    3      | lines line NEWLINE

    4 line: opt_seps
    5     | opt_seps exprs opt_seps
    6     | error

    7 opt_seps: ε
    8         | seps

    9 seps: SEP
   10     | seps SEP

   11 sep_or_nl: SEP
   12          | NEWLINE

   13 exprs: expr
   14      | exprs seps expr

   15 $@1: ε

   16 expr: IF SEP bool_expr SEP $@1 exprs sep_or_nl ENDIF
   17     | CMD arith_expr
   18     | assignment
   19     | LABEL
   20     | GOTO SEP MISC_ID
   21     | SPECIAL_CMD
   22     | CALL SEP STRING
   23     | MISC_ID
   24     | fn
   25     | COMMENT

   26 assignment: VAR '=' arith_expr
   27           | CMD '=' arith_expr
   28           | CUSTOM_VAR '=' arith_expr
   29           | CUSTOM_VAR SEP arith_expr

   30 val: VAR
   31    | CUSTOM_VAR
   32    | INT
   33    | FLOAT

   34 fn: MISC_ID '(' params ')'

   35 params: ε
   36       | arith_expr
   37       | MISC_ID
   38       | params ',' arith_expr
   39       | params ',' MISC_ID

   40 arith_expr: val
   41           | fn
   42           | arith_expr '+' arith_expr
   43           | arith_expr '-' arith_expr
   44           | arith_expr '*' arith_expr
   45           | arith_expr '/' arith_expr
   46           | '(' arith_expr ')'
   47           | '-' arith_expr

   48 bool_expr: arith_expr '<' arith_expr
   49          | arith_expr '>' arith_expr
   50          | arith_expr '=' '=' arith_expr
   51          | arith_expr '!' '=' arith_expr
   52          | arith_expr '<' '=' arith_expr
   53          | arith_expr '>' '=' arith_expr
   54          | '!' bool_expr
   55          | '(' bool_expr ')'


