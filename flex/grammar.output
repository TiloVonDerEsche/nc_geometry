Terminals unused in grammar

    SEMICOLON
    OTHER
    EQ
    NEQ
    LTEQ
    GTEQ


Grammar

    0 $accept: prog $end

    1 prog: lines

    2 lines: ε
    3      | lines line NEWLINE

    4 line: seps
    5     | seps exprs

    6 seps: ε
    7     | seps SEP

    8 exprs: expr
    9      | exprs SEP expr

   10 $@1: ε

   11 expr: IF SEP bool_expr SEP $@1 exprs SEP ENDIF
   12     | CMD arith_expr
   13     | assignment
   14     | LABEL
   15     | GOTO SEP MISC_ID
   16     | SPECIAL_CMD
   17     | CALL SEP STRING
   18     | MISC_ID
   19     | fn
   20     | COMMENT
   21     | error

   22 assignment: VAR '=' arith_expr
   23           | CMD '=' arith_expr
   24           | CUSTOM_VAR '=' arith_expr
   25           | CUSTOM_VAR SEP arith_expr

   26 val: VAR
   27    | CUSTOM_VAR
   28    | INT
   29    | FLOAT

   30 fn: MISC_ID '(' params ')'

   31 params: ε
   32       | arith_expr
   33       | MISC_ID
   34       | params ',' arith_expr
   35       | params ',' MISC_ID

   36 arith_expr: val
   37           | fn
   38           | arith_expr '+' arith_expr
   39           | arith_expr '-' arith_expr
   40           | arith_expr '*' arith_expr
   41           | arith_expr '/' arith_expr
   42           | '(' arith_expr ')'
   43           | '-' arith_expr

   44 bool_expr: arith_expr '<' arith_expr
   45          | arith_expr '>' arith_expr
   46          | arith_expr '=' '=' arith_expr
   47          | arith_expr '!' '=' arith_expr
   48          | arith_expr '<' '=' arith_expr
   49          | arith_expr '>' '=' arith_expr
   50          | '!' bool_expr
   51          | '(' bool_expr ')'


