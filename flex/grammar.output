Terminals unused in grammar

    SEMICOLON
    OTHER
    EQ
    NEQ
    LTEQ
    GTEQ


Grammar

    0 $accept: prog $end

    1 prog: lines

    2 lines: ε
    3      | lines line NEWLINE

    4 line: opt_seps
    5     | opt_seps exprs opt_seps

    6 opt_seps: ε
    7         | seps

    8 seps: SEP
    9     | seps SEP

   10 sep_or_nl: SEP
   11          | NEWLINE

   12 exprs: expr
   13      | exprs seps expr

   14 $@1: ε

   15 expr: IF SEP bool_expr SEP $@1 exprs sep_or_nl ENDIF
   16     | CMD arith_expr
   17     | assignment
   18     | LABEL
   19     | GOTO SEP MISC_ID
   20     | SPECIAL_CMD
   21     | CALL SEP STRING
   22     | MISC_ID
   23     | fn
   24     | COMMENT
   25     | error

   26 assignment: VAR '=' arith_expr
   27           | CMD '=' arith_expr
   28           | CUSTOM_VAR '=' arith_expr
   29           | CUSTOM_VAR SEP arith_expr

   30 val: VAR
   31    | CUSTOM_VAR
   32    | INT
   33    | FLOAT

   34 fn: MISC_ID '(' params ')'

   35 params: ε
   36       | arith_expr
   37       | MISC_ID
   38       | params ',' arith_expr
   39       | params ',' MISC_ID

   40 arith_expr: val
   41           | fn
   42           | arith_expr '+' arith_expr
   43           | arith_expr '-' arith_expr
   44           | arith_expr '*' arith_expr
   45           | arith_expr '/' arith_expr
   46           | '(' arith_expr ')'
   47           | '-' arith_expr

   48 bool_expr: arith_expr '<' arith_expr
   49          | arith_expr '>' arith_expr
   50          | arith_expr '=' '=' arith_expr
   51          | arith_expr '!' '=' arith_expr
   52          | arith_expr '<' '=' arith_expr
   53          | arith_expr '>' '=' arith_expr
   54          | '!' bool_expr
   55          | '(' bool_expr ')'


