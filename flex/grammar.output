Grammar

    0 $accept: prog $end

    1 prog: lines

    2 lines: ε
    3      | lines line NEWLINE

    4 line: exprs

    5 exprs: ε
    6      | expr
    7      | exprs SPACE expr

    8 expr: CMD arith_expr
    9     | assignment
   10     | LABEL
   11     | GOTO SPACE MISC_ID
   12     | SPECIAL_CMD
   13     | CALL SPACE STRING
   14     | MISC_ID
   15     | fn
   16     | COMMENT
   17     | error

   18 assignment: VAR SET arith_expr
   19           | CMD SET arith_expr
   20           | CUSTOM_VAR SET arith_expr
   21           | CUSTOM_VAR SPACE arith_expr

   22 val: VAR
   23    | CUSTOM_VAR
   24    | INT
   25    | FLOAT

   26 fn: MISC_ID '(' params ')'

   27 params: ε
   28       | arith_expr
   29       | MISC_ID
   30       | params ',' arith_expr
   31       | params ',' MISC_ID

   32 arith_expr: val
   33           | fn
   34           | arith_expr '+' arith_expr
   35           | arith_expr '-' arith_expr
   36           | arith_expr '*' arith_expr
   37           | arith_expr '/' arith_expr
   38           | '(' arith_expr ')'
   39           | '-' arith_expr


