   17 val: VAR
   18    | INT
   19    | FLOAT

   20 arith_expr: val
   21           | arith_expr '+' arith_expr
   22           | arith_expr '-' arith_expr
   23           | arith_expr '*' arith_expr
   24           | arith_expr '/' arith_expr
   25           | '(' arith_expr ')'
   26           | '-' arith_expr


