Grammar

    0 $accept: prog $end

    1 prog: lines

    2 lines: ε
    3      | lines line NEWLINE

    4 line: exprs

    5 exprs: ε
    6      | expr
    7      | exprs SPACE expr

    8 expr: CMD arith_expr
    9     | assignment
   10     | LABEL
   11     | SPECIAL_CMD
   12     | CALL SPACE STRING
   13     | MISC_ID
   14     | fn
   15     | COMMENT
   16     | error

   17 assignment: VAR SET arith_expr
   18           | CMD SET arith_expr
   19           | CUSTOM_VAR SET arith_expr
   20           | CUSTOM_VAR SPACE arith_expr

   21 val: VAR
   22    | CUSTOM_VAR
   23    | INT
   24    | FLOAT

   25 fn: MISC_ID '(' params ')'

   26 params: ε
   27       | arith_expr
   28       | MISC_ID
   29       | params ',' arith_expr
   30       | params ',' MISC_ID

   31 arith_expr: val
   32           | fn
   33           | arith_expr '+' arith_expr
   34           | arith_expr '-' arith_expr
   35           | arith_expr '*' arith_expr
   36           | arith_expr '/' arith_expr
   37           | '(' arith_expr ')'
   38           | '-' arith_expr


