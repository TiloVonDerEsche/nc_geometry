OBJS = main.o lex.yy.o lf.yy.o label_finder.o grammar.tab.o helper.o

generate_track_list.exe: $(OBJS)
	x86_64-w64-mingw32-gcc $(OBJS) -o ./../../generate_track_list.exe -lm

helper.o: helper.c helper.h
	x86_64-w64-mingw32-gcc -c helper.c -o helper.o

main.o: main.c
	x86_64-w64-mingw32-gcc -c main.c -o main.o

./label_finder/lf.yy.c: ./label_finder/lf.l
	flex -o ./label_finder/lf.yy.c ./label_finder/lf.l

lf.yy.o: ./label_finder/lf.yy.c
	x86_64-w64-mingw32-gcc -c ./label_finder/lf.yy.c -o lf.yy.o

label_finder.o: ./label_finder/label_finder.c
	x86_64-w64-mingw32-gcc -c ./label_finder/label_finder.c -o label_finder.o

lex.yy.c: lex.l grammar.tab.h
	flex lex.l

lex.yy.o: lex.yy.c
	x86_64-w64-mingw32-gcc -c lex.yy.c -o lex.yy.o

grammar.tab.c grammar.tab.h: grammar.y
	bison -dv grammar.y

grammar.tab.o: grammar.tab.c
	x86_64-w64-mingw32-gcc -c grammar.tab.c -o grammar.tab.o

clean:
	rm -f *.o *.yy.c *.tab.c *.tab.h *.output ./label_finder/*.yy.c
