Terminals unused in grammar

    SEMICOLON
    OTHER
    GOTOF
    GOTO
    REPEAT


Grammar

    0 $accept: prog $end

    1 prog: lines

    2 lines: ε
    3      | lines line NEWLINE

    4 line: opt_seps
    5     | opt_seps opt_skip exprs opt_seps
    6     | error

    7 opt_skip: ε
    8         | '/'

    9 opt_seps: ε
   10         | seps

   11 seps: SEP
   12     | seps SEP

   13 exprs: expr
   14      | exprs seps expr

   15 $@1: ε

   16 expr: IF SEP bool_expr $@1 if_body ENDIF
   17     | CMD arith_expr
   18     | assignment
   19     | LABEL
   20     | GOTOB SEP MISC_ID
   21     | SPECIAL_CMD
   22     | CALL SEP STRING
   23     | MISC_ID
   24     | fn
   25     | COMMENT

   26 if_body: ε
   27        | if_body if_element

   28 if_element: expr
   29           | SEP
   30           | NEWLINE

   31 assignment: CMD opt_seps '=' opt_seps arith_expr
   32           | VAR opt_seps '=' opt_seps arith_expr
   33           | CUSTOM_VAR opt_seps '=' opt_seps arith_expr
   34           | CUSTOM_VAR SEP arith_expr

   35 val: VAR
   36    | CUSTOM_VAR
   37    | INT
   38    | FLOAT

   39 fn: MISC_ID '(' params ')'

   40 params: ε
   41       | arith_expr
   42       | MISC_ID
   43       | params ',' arith_expr
   44       | params ',' MISC_ID

   45 arith_expr: val
   46           | fn
   47           | arith_expr '+' arith_expr
   48           | arith_expr '-' arith_expr
   49           | arith_expr '*' arith_expr
   50           | arith_expr '/' arith_expr
   51           | '(' arith_expr ')'
   52           | '-' arith_expr

   53 bool_expr: arith_expr '<' arith_expr
   54          | arith_expr '>' arith_expr
   55          | arith_expr '=' '=' arith_expr
   56          | arith_expr '!' '=' arith_expr
   57          | arith_expr '<' '=' arith_expr
   58          | arith_expr '>' '=' arith_expr
   59          | '!' bool_expr
   60          | '(' bool_expr ')'


