Terminals unused in grammar

    END
    OTHER


Grammar

    0 $accept: prog $end

    1 prog: lines $end

    2 lines: ε
    3      | lines line NEWLINE

    4 line: opt_seps
    5     | opt_seps opt_skip exprs opt_seps
    6     | error

    7 opt_skip: ε
    8         | '/'

    9 opt_seps: ε
   10         | seps

   11 seps: SEP
   12     | seps SEP

   13 exprs: expr
   14      | exprs seps expr

   15 $@1: ε

   16 expr: IF SEP bool_expr $@1 if_body ENDIF
   17     | CMD arith_expr
   18     | assignment
   19     | LABEL
   20     | GOTO SEP MISC_ID
   21     | REPEAT SEP MISC_ID SEP MISC_ID
   22     | SPECIAL_CMD
   23     | MSG SEP STRING
   24     | MISC_ID
   25     | fn
   26     | COMMENT

   27 if_body: ε
   28        | if_body if_element

   29 if_element: expr
   30           | SEP
   31           | NEWLINE

   32 assignment: CMD opt_seps '=' opt_seps arith_expr
   33           | VAR opt_seps '=' opt_seps arith_expr
   34           | CUSTOM_VAR opt_seps '=' opt_seps arith_expr
   35           | CUSTOM_VAR SEP arith_expr

   36 val: VAR
   37    | CUSTOM_VAR
   38    | INT
   39    | FLOAT

   40 fn: MISC_ID '(' params ')'

   41 params: ε
   42       | arith_expr
   43       | MISC_ID
   44       | params ',' arith_expr
   45       | params ',' MISC_ID

   46 arith_expr: val
   47           | fn
   48           | arith_expr '+' arith_expr
   49           | arith_expr '-' arith_expr
   50           | arith_expr '*' arith_expr
   51           | arith_expr '/' arith_expr
   52           | '(' arith_expr ')'
   53           | '-' arith_expr

   54 bool_expr: arith_expr '<' arith_expr
   55          | arith_expr '>' arith_expr
   56          | arith_expr '=' '=' arith_expr
   57          | arith_expr '!' '=' arith_expr
   58          | arith_expr '<' '=' arith_expr
   59          | arith_expr '>' '=' arith_expr
   60          | '!' bool_expr
   61          | '(' bool_expr ')'


