Terminals unused in grammar

    END
    OTHER


Grammar

    0 $accept: prog $end

    1 prog: lines $end

    2 lines: ε
    3      | lines line NEWLINE

    4 line: opt_seps
    5     | opt_seps opt_skip exprs opt_seps
    6     | error

    7 opt_skip: ε
    8         | '/'

    9 opt_seps: ε
   10         | seps

   11 seps: SEP
   12     | seps SEP

   13 exprs: expr
   14      | exprs seps expr

   15 $@1: ε

   16 expr: IF SEP bool_expr $@1 if_body ENDIF
   17     | G_CMD arith_expr
   18     | XYZ_CMD arith_expr
   19     | ABC_CMD arith_expr
   20     | CMD arith_expr
   21     | ROT
   22     | assignment
   23     | LABEL
   24     | GOTO SEP MISC_ID
   25     | REPEAT SEP MISC_ID
   26     | REPEAT SEP MISC_ID SEP MISC_ID
   27     | SPECIAL_CMD
   28     | MSG SEP STRING
   29     | MISC_ID
   30     | fn
   31     | COMMENT

   32 if_body: ε
   33        | if_body if_element

   34 if_element: expr
   35           | SEP
   36           | NEWLINE

   37 assignment: XYZ_CMD opt_seps '=' opt_seps arith_expr
   38           | ABC_CMD opt_seps '=' opt_seps arith_expr
   39           | VAR opt_seps '=' opt_seps arith_expr
   40           | CUSTOM_VAR opt_seps '=' opt_seps arith_expr
   41           | CUSTOM_VAR SEP arith_expr

   42 val: VAR
   43    | CUSTOM_VAR
   44    | INT
   45    | FLOAT

   46 fn: MISC_ID '(' params ')'

   47 params: ε
   48       | arith_expr
   49       | MISC_ID
   50       | params ',' arith_expr
   51       | params ',' MISC_ID

   52 arith_expr: val
   53           | fn
   54           | arith_expr '+' arith_expr
   55           | arith_expr '-' arith_expr
   56           | arith_expr '*' arith_expr
   57           | arith_expr '/' arith_expr
   58           | '(' arith_expr ')'
   59           | '-' arith_expr

   60 bool_expr: arith_expr '<' arith_expr
   61          | arith_expr '>' arith_expr
   62          | arith_expr '=' '=' arith_expr
   63          | arith_expr '!' '=' arith_expr
   64          | arith_expr '<' '=' arith_expr
   65          | arith_expr '>' '=' arith_expr
   66          | '!' bool_expr
   67          | '(' bool_expr ')'


