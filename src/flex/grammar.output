State 0 conflicts: 1 shift/reduce


Grammar

    0 $accept: prog $end

    1 prog: lines $end
    2     | $end

    3 lines: ε
    4      | lines line NEWLINE

    5 line: opt_seps
    6     | opt_seps opt_skip exprs opt_seps
    7     | error

    8 opt_skip: ε
    9         | '/'

   10 opt_seps: ε
   11         | seps

   12 seps: SEP
   13     | seps SEP

   14 exprs: expr
   15      | exprs seps expr

   16 $@1: ε

   17 expr: IF SEP bool_expr $@1 if_body ENDIF
   18     | CMD arith_expr
   19     | assignment
   20     | LABEL
   21     | GOTO SEP MISC_ID
   22     | REPEAT SEP MISC_ID SEP MISC_ID
   23     | SPECIAL_CMD
   24     | CALL SEP STRING
   25     | MISC_ID
   26     | fn
   27     | COMMENT

   28 if_body: ε
   29        | if_body if_element

   30 if_element: expr
   31           | SEP
   32           | NEWLINE

   33 assignment: CMD opt_seps '=' opt_seps arith_expr
   34           | VAR opt_seps '=' opt_seps arith_expr
   35           | CUSTOM_VAR opt_seps '=' opt_seps arith_expr
   36           | CUSTOM_VAR SEP arith_expr

   37 val: VAR
   38    | CUSTOM_VAR
   39    | INT
   40    | FLOAT

   41 fn: MISC_ID '(' params ')'

   42 params: ε
   43       | arith_expr
   44       | MISC_ID
   45       | params ',' arith_expr
   46       | params ',' MISC_ID

   47 arith_expr: val
   48           | fn
   49           | arith_expr '+' arith_expr
   50           | arith_expr '-' arith_expr
   51           | arith_expr '*' arith_expr
   52           | arith_expr '/' arith_expr
   53           | '(' arith_expr ')'
   54           | '-' arith_expr

   55 bool_expr: arith_expr '<' arith_expr
   56          | arith_expr '>' arith_expr
   57          | arith_expr '=' '=' arith_expr
   58          | arith_expr '!' '=' arith_expr
   59          | arith_expr '<' '=' arith_expr
   60          | arith_expr '>' '=' arith_expr
   61          | '!' bool_expr
   62          | '(' bool_expr ')'


