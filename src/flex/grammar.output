Terminals unused in grammar

    END
    OTHER
    XYZ_CMD
    ABC_CMD


Grammar

    0 $accept: prog $end

    1 prog: lines $end

    2 lines: ε
    3      | lines line NEWLINE

    4 line: opt_seps
    5     | opt_seps opt_skip exprs opt_seps
    6     | error

    7 opt_skip: ε
    8         | '/'

    9 opt_seps: ε
   10         | seps

   11 seps: SEP
   12     | seps SEP

   13 exprs: expr
   14      | exprs seps expr

   15 $@1: ε

   16 expr: IF SEP bool_expr $@1 if_body ENDIF
   17     | CMD arith_expr
   18     | ROT
   19     | assignment
   20     | LABEL
   21     | GOTO SEP MISC_ID
   22     | REPEAT SEP MISC_ID
   23     | REPEAT SEP MISC_ID SEP MISC_ID
   24     | SPECIAL_CMD
   25     | MSG SEP STRING
   26     | MISC_ID
   27     | fn
   28     | COMMENT

   29 if_body: ε
   30        | if_body if_element

   31 if_element: expr
   32           | SEP
   33           | NEWLINE

   34 assignment: CMD opt_seps '=' opt_seps arith_expr
   35           | VAR opt_seps '=' opt_seps arith_expr
   36           | CUSTOM_VAR opt_seps '=' opt_seps arith_expr
   37           | CUSTOM_VAR SEP arith_expr

   38 val: VAR
   39    | CUSTOM_VAR
   40    | INT
   41    | FLOAT

   42 fn: MISC_ID '(' params ')'

   43 params: ε
   44       | arith_expr
   45       | MISC_ID
   46       | params ',' arith_expr
   47       | params ',' MISC_ID

   48 arith_expr: val
   49           | fn
   50           | arith_expr '+' arith_expr
   51           | arith_expr '-' arith_expr
   52           | arith_expr '*' arith_expr
   53           | arith_expr '/' arith_expr
   54           | '(' arith_expr ')'
   55           | '-' arith_expr

   56 bool_expr: arith_expr '<' arith_expr
   57          | arith_expr '>' arith_expr
   58          | arith_expr '=' '=' arith_expr
   59          | arith_expr '!' '=' arith_expr
   60          | arith_expr '<' '=' arith_expr
   61          | arith_expr '>' '=' arith_expr
   62          | '!' bool_expr
   63          | '(' bool_expr ')'


